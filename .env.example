# ====== 前端构建时变量 ======
VITE_API_BASE_URL=http://localhost:3001
VITE_UPLOAD_BASE_URL=/api/oss
VITE_LEAFER_INVITECODE=你的公测邀请码
VITE_API_AUTH_KEY=你的API鉴权密钥

# ====== 后端变量 ======
NODE_ENV=production
HAIBAO_PORT=3001

# CORS 白名单（逗号分隔）
CORS_ORIGINS=https://yourdomain.com

# API 鉴权密钥（与 VITE_API_AUTH_KEY 一致，留空则跳过鉴权）
API_AUTH_KEY=你的API鉴权密钥

# 硅基流动 SiliconFlow（图像生成）
SILICONFLOW_API_KEY=你的key
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_IMAGE_MODEL=Tongyi-MAI/Z-Image-Turbo
SILICONFLOW_EDIT_MODEL=Qwen/Qwen-Image-Edit

# 通义万相 DashScope（文生图）
DASHSCOPE_API_KEY=你的key
DASHSCOPE_MODEL=wanx2.1-t2i-turbo

# LLM 对话模型（通用配置）
# API 格式：'openai' 或 'anthropic'
LLM_API_FORMAT=anthropic
LLM_API_KEY=你的key
LLM_BASE_URL=https://token-plan-cn.xiaomimimo.com
LLM_MODEL_ID=mimo-v2.5-pro
